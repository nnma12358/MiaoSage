# ============================================================
# 苗绣·识裳 — K1 开发板专用镜像（riscv64 + ONNX Runtime）
# ============================================================
# 构建策略：前端在 PC 预构建 → 拷贝 build/ 到 K1 → K1 上 Docker build
#
# PC 端：
#   npm install && npm run build
#   scp -r build/ deploy/Dockerfile.k1 deploy/docker-compose.k1.yml root@k1:/opt/miao-xiu/
#
# K1 端：
#   cd /opt/miao-xiu
#   docker compose -f docker-compose.k1.yml up -d --build
#
# 性能预估（K1 CPU + spacemit-ort）：
#   YOLOv8n ONNX: ~300-800ms/帧  内存: ~400MB  并发: 1-2 用户
# ============================================================

FROM python:3.11-slim-bookworm

LABEL org.miao-xiu.platform="riscv64-k1"
LABEL org.miao-xiu.description="K1 board optimized image with spacemit-ort ONNX Runtime"

# ---- 系统依赖 ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libopenblas0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Layer 1: pip 依赖 ----
# K1 板专用 spacemit-ort（riscv64 预编译，官方优化 ONNX Runtime）
COPY server/requirements.txt /app/
RUN pip install --no-cache-dir --index-url https://git.spacemit.com/api/v4/projects/33/packages/pypi/simple spacemit-ort && \
    pip install --no-cache-dir -r requirements.txt && \
    python -c "import onnxruntime; print('✓ spacemit-ort:', onnxruntime.__version__)"

# ---- Layer 2: 性能模块 ----
COPY server/perf.py /app/

# ---- Layer 3: 后端服务 ----
COPY server/board_server.py /app/

# ---- Layer 4: 前端（PC 预构建产物）----
COPY build/ /app/build/

# ---- 环境变量 ----
ENV YOLO_MODEL=yolov8n.onnx
ENV OLLAMA_HOST=http://127.0.0.1:11434
ENV OLLAMA_MODEL=qwen2.5-instruct
# K1 通常无外网 Ollama，LLM 对话暂不可用；图像识别完全独立

HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
    CMD curl -f http://localhost:80/health || exit 1

EXPOSE 80

# uvicorn 单 worker（K1 多核但 ONNX 推理为单线程瓶颈，多 worker 反而争抢 CPU）
CMD ["python", "-m", "uvicorn", "board_server:app", \
     "--host", "0.0.0.0", "--port", "80", \
     "--workers", "1", "--log-level", "info"]
