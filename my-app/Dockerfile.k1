# ============================================================
# 苗绣·识裳 — K1 API 网关（多容器架构）
# ============================================================
# 本容器仅负责：前端 SPA + API 路由代理
# YOLO / ASR / TTS 分别在独立容器中运行
# ============================================================
FROM ubuntu:24.04

# 优先阿里云镜像（K1 直连 ports.ubuntu.com 超时）
RUN sed -i "s@http://ports.ubuntu.com/@http://mirrors.aliyun.com/@g" /etc/apt/sources.list.d/ubuntu.sources && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev curl openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --break-system-packages --no-cache-dir \
    --index-url https://git.spacemit.com/api/v4/projects/33/packages/pypi/simple \
    fastapi uvicorn requests python-multipart && \
    rm -rf /root/.cache/pip/*

# ---- 前端 SPA ----
COPY build/ /app/build/

# ---- 网关服务 + 性能监控 ----
COPY server/gateway_server.py server/perf.py /app/

# ---- SSL 证书 ----
RUN mkdir -p /app/certs && \
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
        -keyout /app/certs/key.pem \
        -out /app/certs/cert.pem \
        -subj "/CN=K1-MiaoXiu"

ENV OLLAMA_HOST=http://127.0.0.1:11434
ENV OLLAMA_MODEL=qwen2.5-instruct
ENV YOLO_URL=http://127.0.0.1:8000
ENV ASR_URL=http://127.0.0.1:8001
ENV TTS_URL=http://127.0.0.1:8002

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -fk https://localhost:443/health || exit 1

EXPOSE 443

CMD python3 -m uvicorn gateway_server:app \
    --host 0.0.0.0 --port 443 \
    --ssl-keyfile /app/certs/key.pem \
    --ssl-certfile /app/certs/cert.pem \
    --workers 1 --log-level info
