# ============================================================
# 苗绣·识裳 — 统一镜像（静态前端 + Python 后端一体化）
# ============================================================
# 单容器部署：一个 Python 进程同时服务前端 SPA 和全部 API
# 无需 Nginx、无需多容器编排，极简运维
#
# 构建：
#   docker build -f Dockerfile.unified -t miao-xiu:unified .
#
# 运行（仅 YOLO，无 LLM）：
#   docker run -d -p 80:80 miao-xiu:unified
#
# 运行（连接外部 Ollama）：
#   docker run -d -p 80:80 \
#     -e OLLAMA_HOST=http://host.docker.internal:11434 \
#     miao-xiu:unified
# ============================================================

# ---- Stage 1: 构建 Svelte 前端 ----
FROM node:22-alpine AS frontend

WORKDIR /app
COPY package.json ./
RUN npm install --ignore-scripts

COPY . .
RUN npm run build

# ---- Stage 2: Python 运行时 ----
FROM python:3.11-slim-bookworm

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx libglib2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Layer 1: Python 依赖 ----
COPY server/requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# ---- Layer 2: 性能模块 ----
COPY server/perf.py /app/

# ---- Layer 3: 后端服务 ----
COPY server/board_server.py /app/

# ---- Layer 4: 前端构建产物 ----
COPY --from=frontend /app/build /app/build

# 健康检查
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:80/health || exit 1

# 默认仅启动 YOLO + 前端（无 ASR/TTS/Ollama）
ENV OLLAMA_HOST=http://127.0.0.1:11434
ENV OLLAMA_MODEL=qwen2.5-instruct
ENV YOLO_MODEL=yolov8n.onnx

EXPOSE 80

CMD ["python", "board_server.py", "--port", "80", "--host", "0.0.0.0"]
