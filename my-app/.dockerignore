# ============================================================
# Docker 构建忽略 — 缩减上下文，加速构建
# ============================================================

# Node
node_modules/
.svelte-kit/
npm-debug.log*
package-lock.json

# Python（构建时由 pip install 重新安装）
server/__pycache__/
server/venv/
*.py[cod]
*.egg-info/

# 前端构建产物（Docker 内 npm run build 重新生成）
build/

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo

# OS 杂项
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Docker 自身
Dockerfile*
docker-compose*.yml
.dockerignore

# 部署脚本（镜像内不需要）
deploy/

# 文档
*.md
!README.md

# 日志
logs/
*.log

# 临时文件
tmp/
temp/
*.tmp
*.tar.gz

# 环境变量
.env
.env.*
